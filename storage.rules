rules_version = '2';

// Firebase Storage Security Rules for EEN Capture Application
// PROTECT BOTH CONTENT AND METADATA
service firebase.storage {
  match /b/{bucket}/o {
    // Rules for capture images: captures/{captureId}/{imageFile}
    match /captures/{captureId}/{imageFile} {
      // Allow public read access for file content (when accessed with ?alt=media)
      // Require authentication for metadata access (when accessed without ?alt=media)
      allow read: if request.query.alt == 'media' || request.auth != null;
      
      // Secure write rule - require authentication and basic metadata
      allow write: if request.auth != null &&
                      request.auth.token.eenUserEmail != null &&
                      request.resource.metadata != null;
        
      // Allow delete for authenticated users
      allow delete: if request.auth != null;
    }
    
    // Deny all other access explicitly
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
} 